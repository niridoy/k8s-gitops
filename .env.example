# Copy to .env for docker compose: cp .env.example .env

DB_ROOT_PASSWORD=rootpassword
DB_NAME=appdb
DB_USER=user
DB_PASSWORD=password
MYSQL_PORT=3306

# Used by scripts/setup-local-mysql.sh (Minikube host gateway IP for pod → host MySQL)
# Run the script to auto-detect, or set manually (example: 192.168.220.1)
MYSQL_GATEWAY_IP=
